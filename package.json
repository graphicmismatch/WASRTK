{
  "name": "wasrtk",
  "version": "1.0.0",
  "description": "A powerful pixel art and animation tool for rotoscoping and traditional animation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run format:check"
  },
  "keywords": [
    "pixel-art",
    "animation",
    "rotoscoping",
    "drawing",
    "electron"
  ],
  "author": "WASRTK",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "electron": "^13.1.7",
    "electron-builder": "^22.11.7",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "gif.js": "^0.2.0"
  },
  "build": {
    "appId": "com.wasrtk.app",
    "productName": "WASRTK",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "assets/icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "linux",
      "desktop": {
        "StartupWMClass": "wasrtk"
      }
    }
  }
}
